{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "thasmo-resume",
	"compatibility_date": "2026-01-01",
	"compatibility_flags": ["nodejs_compat"],
	"preview_urls": true,
	"observability": {
		"enabled": true,
		"head_sampling_rate": 1
	},
	"kv_namespaces": [
		{
			"binding": "FILES",
			"id": "6fe535cdeca144be96e7bd265984c794"
		}
	],
	"routes": [
		{
			"pattern": "resume.thasmo.com",
			"custom_domain": true
		}
	]
}
